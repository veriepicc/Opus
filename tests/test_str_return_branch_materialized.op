function str pick_text(int slot) {
    if slot == 0 {
        return "abc"
    }
    if slot == 1 {
        return "def"
    }
    return "xyz"
}

function int main() {
    var a = pick_text(0)
    var b = pick_text(1)
    var c = pick_text(2)
    if string_equals(a, "abc") != 1 {
        return 1
    }
    if string_equals(b, "def") != 1 {
        return 2
    }
    if string_equals(c, "xyz") != 1 {
        return 3
    }
    return 0
}
