function str pick_text(int slot) {
    if slot == 0 {
        return "abc"
    }
    if slot == 1 {
        return "def"
    }
    return "xyz"
}

function int main() {
    let text = pick_text(2)
    if string_equals(text, "abc") == 1 {
        return 11
    }
    if string_equals(text, "def") == 1 {
        return 12
    }
    if string_equals(text, "xyz") == 1 {
        return 13
    }
    return 14
}
