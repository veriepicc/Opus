import mem

function int main() {
    let block = mem.make_zero(32)
    if block == 0 {
        return 1
    }

    mem.write(block + 0, 0x1122334455667788)
    mem.write32(block + 8, 123456)
    mem.textz(block + 16, "ok")

    if mem.read(block + 0) != 0x1122334455667788 {
        return 2
    }
    if mem.read32(block + 8) != 123456 {
        return 3
    }
    if mem.read8(block + 16) != 111 {
        return 4
    }
    if mem.read8(block + 17) != 107 {
        return 5
    }
    if mem.read8(block + 18) != 0 {
        return 6
    }

    mem.free_ptr(block)
    return 0
}
