function int main() {
    print("=== break/continue test ===\n")

    // test 1: break in inner for, outer keeps going
    var outer_count = 0
    for i in range(0, 3) {
        for j in range(0, 10) {
            if j == 2 {
                break
            }
        }
        outer_count += 1
    }
    if outer_count == 3 {
        print("PASS: break inner, outer ran 3 times\n")
    }
    if outer_count != 3 {
        print("FAIL: break inner, outer count wrong\n")
    }

    // test 2: continue in inner for, outer keeps going
    var skip_count = 0
    for i in range(0, 3) {
        for j in range(0, 4) {
            if j == 1 {
                continue
            }
            skip_count += 1
        }
    }
    // each inner loop: 4 iters, skip 1 = 3 counted, times 3 outer = 9
    if skip_count == 9 {
        print("PASS: continue inner, counted 9\n")
    }
    if skip_count != 9 {
        print("FAIL: continue inner, count wrong\n")
    }

    // test 3: break in while inside for
    var while_breaks = 0
    for i in range(0, 3) {
        var w = 0
        while w < 100 {
            if w == 5 {
                break
            }
            w += 1
        }
        while_breaks += w
    }
    // each while runs to w=5 then breaks, 3 times = 15
    if while_breaks == 15 {
        print("PASS: break in while inside for, sum 15\n")
    }
    if while_breaks != 15 {
        print("FAIL: break in while inside for wrong\n")
    }

    // test 4: continue in for only affects innermost
    var total = 0
    for i in range(0, 5) {
        if i == 2 {
            continue
        }
        total += 1
    }
    // skips i=2, so 4 iterations counted
    if total == 4 {
        print("PASS: continue skips i=2, total 4\n")
    }
    if total != 4 {
        print("FAIL: continue skip wrong\n")
    }

    print("=== done ===\n")
    return 0
}
