// else-if chain verification

function int main() {
    alloc_console()
    print("=== else-if chain tests ===\n")

    // test 1: first branch matches
    var x = 10
    var result = 0
    if x == 10 {
        result = 1
    } else if x == 20 {
        result = 2
    } else {
        result = 3
    }
    if result != 1 {
        print("FAIL test 1: expected 1\n")
        return 1
    }
    print("PASS test 1: first branch\n")

    // test 2: second branch matches
    x = 20
    result = 0
    if x == 10 {
        result = 1
    } else if x == 20 {
        result = 2
    } else {
        result = 3
    }
    if result != 2 {
        print("FAIL test 2: expected 2\n")
        return 2
    }
    print("PASS test 2: second branch\n")

    // test 3: else branch
    x = 99
    result = 0
    if x == 10 {
        result = 1
    } else if x == 20 {
        result = 2
    } else {
        result = 3
    }
    if result != 3 {
        print("FAIL test 3: expected 3\n")
        return 3
    }
    print("PASS test 3: else branch\n")

    // test 4: 4-way chain
    x = 30
    result = 0
    if x == 10 {
        result = 1
    } else if x == 20 {
        result = 2
    } else if x == 30 {
        result = 3
    } else {
        result = 4
    }
    if result != 3 {
        print("FAIL test 4: expected 3\n")
        return 4
    }
    print("PASS test 4: 4-way chain\n")

    // test 5: no else, no match (result stays 0)
    x = 50
    result = 0
    if x == 10 {
        result = 1
    } else if x == 20 {
        result = 2
    }
    if result != 0 {
        print("FAIL test 5: expected 0\n")
        return 5
    }
    print("PASS test 5: no match no else\n")

    print("=== all else-if tests passed ===\n")
    return 0
}
