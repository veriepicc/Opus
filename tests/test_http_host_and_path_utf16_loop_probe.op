import http

function int main() {
    let parsed = http_parse_url("https://example.com")
    if parsed == 0 {
        return 1
    }

    let host_text = parsed.host
    let host_len = string_length(host_text)
    let host_w = http_make_zero((host_len + 1) * 2)
    if host_w == 0 {
        return 2
    }
    var host_i = 0
    while host_i < host_len {
        mem_write_i16(host_w + host_i * 2, char_at(host_text, host_i))
        host_i++
    }

    let path_text = parsed.path
    let path_len = string_length(path_text)
    let path_w = http_make_zero((path_len + 1) * 2)
    if path_w == 0 {
        return 3
    }
    var path_i = 0
    while path_i < path_len {
        mem_write_i16(path_w + path_i * 2, char_at(path_text, path_i))
        path_i++
    }

    return 4
}
