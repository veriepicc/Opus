import test_import_str_lib

function int main() {
    if len_wrap("abcd") != 4 {
        return 1
    }

    if starts_with_wrap("https://example.com", "https://") == 0 {
        return 2
    }

    let cloned = clone_wrap("opus")
    if string_length(cloned) != 4 {
        return 3
    }

    return 0
}
