function str pick_text(int slot) {
    if slot == 0 {
        return "abc"
    }
    if slot == 1 {
        return "def"
    }
    return "xyz"
}

function int sink(int a, int b, int c, int d, int e) {
    return a + b + c + d + e
}

function int main() {
    var a = pick_text(0)
    var b = pick_text(1)
    var c = pick_text(2)
    let junk = sink(1, 2, 3, 4, 5)
    if junk != 15 {
        return 9
    }
    if string_equals(a, "abc") != 1 {
        return 1
    }
    if string_equals(b, "def") != 1 {
        return 2
    }
    if string_equals(c, "xyz") != 1 {
        return 3
    }
    return 0
}
