function int add5(int a, int b, int c, int d, int e) {
    return a + b + c + d + e
}

function int add6(int a, int b, int c, int d, int e, int f) {
    return a + b + c + d + e + f
}

function int main() {
    print("=== 5+ args test ===\n")

    // test 1: 5 args
    let r1 = add5(10, 20, 30, 40, 50)
    if r1 == 150 {
        print("PASS: add5(10,20,30,40,50) == 150\n")
    }
    if r1 != 150 {
        print("FAIL: add5 returned wrong value\n")
    }

    // test 2: 6 args
    let r2 = add6(1, 2, 3, 4, 5, 6)
    if r2 == 21 {
        print("PASS: add6(1,2,3,4,5,6) == 21\n")
    }
    if r2 != 21 {
        print("FAIL: add6 returned wrong value\n")
    }

    // test 3: 5 args with expressions
    let x = 100
    let r3 = add5(x, x + 1, x + 2, x + 3, x + 4)
    if r3 == 510 {
        print("PASS: add5 with expressions == 510\n")
    }
    if r3 != 510 {
        print("FAIL: add5 with expressions wrong\n")
    }

    print("=== done ===\n")
    return 0
}
