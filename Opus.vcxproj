    </Link>
    <PreBuildEvent>
      <Command>powershell -NoProfile -ExecutionPolicy Bypass -File "$(ProjectDir)tools\generate-stdlib-module.ps1" -StdlibDir "$(ProjectDir)stdlib" -OutputPath "$(ProjectDir)src\stdlib.ixx"</Command>
