// recursive fibonacci
function int fib(int n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

function int main() {
    print("fibonacci sequence:\n")
    for i in range(0, 21) {
        print("fib(")
        print_int(i)
        print(") = ")
        print_int(fib(i))
    }

    return 0
}
